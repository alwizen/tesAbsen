<?php
// database/seeders/DatabaseSeeder.php

namespace Database\Seeders;

use App\Models\Department;
use App\Models\User;
use Illuminate\Database\Seeder;
use App\Models\WorkSchedule;
use App\Models\Employee;
use Illuminate\Support\Facades\Hash;

class DatabaseSeeder extends Seeder
{
    public function run(): void
    {
        // Create Filament Users
        User::create([
            'name' => 'Super Admin',
            'email' => 'admin@admin.com',
            'password' => Hash::make('password'),
            'email_verified_at' => now(),
        ]);

        User::create([
            'name' => 'Supervisor Dapur',
            'email' => 'supervisor@example.com',
            'password' => Hash::make('password'),
            'email_verified_at' => now(),
        ]);

        // Create Departments
        $timPersiapan = Department::create([
            'name' => 'Tim Persiapan',
            'code' => 'PREP-01',
            'description' => 'Tim persiapan bahan makanan',
            'is_active' => true,
        ]);

        $timPengolahan = Department::create([
            'name' => 'Tim Pengolahan',
            'code' => 'COOK-01',
            'description' => 'Tim pengolahan dan memasak',
            'is_active' => true,
        ]);

        $timPemorsian = Department::create([
            'name' => 'Tim Pemorsian',
            'code' => 'PORT-01',
            'description' => 'Tim pemorsian makanan',
            'is_active' => true,
        ]);

        $timDistribusi = Department::create([
            'name' => 'Tim Distribusi',
            'code' => 'DIST-01',
            'description' => 'Tim distribusi makanan',
            'is_active' => true,
        ]);

        $timCuciShift1 = Department::create([
            'name' => 'Tim Cuci Ompreng Shift 1',
            'code' => 'WASH1-01',
            'description' => 'Tim cuci peralatan shift 1',
            'is_active' => true,
        ]);

        $timCuciShift2 = Department::create([
            'name' => 'Tim Cuci Ompreng Shift 2',
            'code' => 'WASH2-01',
            'description' => 'Tim cuci peralatan shift 2',
            'is_active' => true,
        ]);

        $timKebersihan = Department::create([
            'name' => 'Tim Petugas Kebersihan',
            'code' => 'CLEAN-01',
            'description' => 'Tim petugas kebersihan',
            'is_active' => true,
        ]);

        $spvDapur = Department::create([
            'name' => 'Supervisor Dapur',
            'code' => 'SPV-01',
            'description' => 'Supervisor dapur',
            'is_active' => true,
        ]);

        // Create Work Schedules

        // Tim Persiapan: 19.00 - 03.00 (overnight)
        WorkSchedule::create([
            'department_id' => $timPersiapan->id,
            'check_in_time' => '19:00:00',
            'check_out_time' => '03:00:00',
            'grace_period_minutes' => 15,
            'is_overnight' => true,
            'max_work_hours' => 8,
            'is_active' => true,
        ]);

        // Tim Pengolahan: 00.00 - 08.00
        WorkSchedule::create([
            'department_id' => $timPengolahan->id,
            'check_in_time' => '00:00:00',
            'check_out_time' => '08:00:00',
            'grace_period_minutes' => 15,
            'is_overnight' => false,
            'max_work_hours' => 8,
            'is_active' => true,
        ]);

        // Tim Pemorsian: 04.00 - 12.00
        WorkSchedule::create([
            'department_id' => $timPemorsian->id,
            'check_in_time' => '04:00:00',
            'check_out_time' => '12:00:00',
            'grace_period_minutes' => 15,
            'is_overnight' => false,
            'max_work_hours' => 8,
            'is_active' => true,
        ]);

        // Tim Distribusi: 06.00 - 14.00
        WorkSchedule::create([
            'department_id' => $timDistribusi->id,
            'check_in_time' => '06:00:00',
            'check_out_time' => '14:00:00',
            'grace_period_minutes' => 15,
            'is_overnight' => false,
            'max_work_hours' => 8,
            'is_active' => true,
        ]);

        // Tim Cuci Ompreng Shift 1: 11.00 - 19.00
        WorkSchedule::create([
            'department_id' => $timCuciShift1->id,
            'check_in_time' => '11:00:00',
            'check_out_time' => '19:00:00',
            'grace_period_minutes' => 15,
            'is_overnight' => false,
            'max_work_hours' => 8,
            'is_active' => true,
        ]);

        // Tim Cuci Ompreng Shift 2: 16.00 - 00.00 (overnight)
        WorkSchedule::create([
            'department_id' => $timCuciShift2->id,
            'check_in_time' => '16:00:00',
            'check_out_time' => '00:00:00',
            'grace_period_minutes' => 15,
            'is_overnight' => true,
            'max_work_hours' => 8,
            'is_active' => true,
        ]);

        // Tim Petugas Kebersihan: 11.00 - 19.00 
        WorkSchedule::create([
            'department_id' => $timKebersihan->id,
            'check_in_time' => '11:00:00',
            'check_out_time' => '19:00:00',
            'grace_period_minutes' => 15,
            'is_overnight' => false,
            'max_work_hours' => 8,
            'is_active' => true,
        ]);

        // Supervisor Dapur: 05.00 - 17.00
        WorkSchedule::create([
            'department_id' => $spvDapur->id,
            'check_in_time' => '05:00:00',
            'check_out_time' => '17:00:00',
            'grace_period_minutes' => 10,
            'is_overnight' => false,
            'max_work_hours' => 12,
            'is_active' => true,
        ]);

        // Create Sample Employees

        // Tim Persiapan
        Employee::create([
            'rfid_number' => '1',
            'employee_number' => 'PREP001',
            'name' => 'Budi Santoso',
            'department_id' => $timPersiapan->id,
