            'salary_type' => 'daily',
            'daily_rate' => 120000,
            'hourly_rate' => 0,
            'allowance' => 10000,
            'pj_allowance' => 15000,
        ]);

        $timPengolahan = Department::create([
            'name' => 'Tim Pengolahan',
            'code' => 'COOK-01',
