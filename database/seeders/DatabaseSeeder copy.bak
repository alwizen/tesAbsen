            'is_active' => true,
        ]);

        Employee::create([
            'rfid_number' => '2',
            'employee_number' => 'PREP002',
            'name' => 'Siti Aminah',
            'department_id' => $timPersiapan->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        // Tim Pengolahan
        Employee::create([
            'rfid_number' => '3',
            'employee_number' => 'COOK001',
            'name' => 'Ahmad Wijaya',
            'department_id' => $timPengolahan->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        Employee::create([
            'rfid_number' => '4',
            'employee_number' => 'COOK002',
            'name' => 'Dewi Lestari',
            'department_id' => $timPengolahan->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        // Tim Pemorsian
        Employee::create([
            'rfid_number' => '5',
            'employee_number' => 'PORT001',
            'name' => 'Eko Prasetyo',
            'department_id' => $timPemorsian->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        // Tim Distribusi
        Employee::create([
            'rfid_number' => '6',
            'employee_number' => 'DIST001',
            'name' => 'Fitri Handayani',
            'department_id' => $timDistribusi->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        // Tim Cuci Ompreng Shift 1
        Employee::create([
            'rfid_number' => '7',
            'employee_number' => 'WASH101',
            'name' => 'Gunawan Setiawan',
            'department_id' => $timCuciShift1->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        // Tim Cuci Ompreng Shift 2
        Employee::create([
            'rfid_number' => '8',
            'employee_number' => 'WASH201',
            'name' => 'Hendra Kusuma',
            'department_id' => $timCuciShift2->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        // Tim Petugas Kebersihan
        Employee::create([
            'rfid_number' => '9',
            'employee_number' => 'CLEAN001',
            'name' => 'Indah Permata',
            'department_id' => $timKebersihan->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        Employee::create([
            'rfid_number' => '10',
            'employee_number' => 'CLEAN002',
            'name' => 'Joko Susilo',
            'department_id' => $timKebersihan->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);

        // Supervisor Dapur
        Employee::create([
            'rfid_number' => '11',
            'employee_number' => 'SPV001',
            'name' => 'Kartika Sari',
            'department_id' => $spvDapur->id,
            'join_date' => '2024-01-01',
            'is_active' => true,
        ]);
    }
}
